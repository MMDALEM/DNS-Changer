<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <AssemblyName>DnsChanger</AssemblyName>
    <RootNamespace>DnsChanger</RootNamespace>
    <Product>DNS Changer</Product>
    <Version>1.0.0</Version>
    <AssemblyVersion>1.0.0.0</AssemblyVersion>
    <FileVersion>1.0.0.0</FileVersion>
    <Authors>Mohammad Alemzadeh</Authors>
    <Description>A simple, modern DNS changer for Windows.</Description>
    <!-- Single-file friendly publish defaults -->
    <SelfContained>false</SelfContained>
    <RuntimeIdentifier Condition="'$(PublishSingleFile)' == 'true'">win-x64</RuntimeIdentifier>
  </PropertyGroup>

</Project>
