<Window x:Class="DnsChanger.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DNS Changer" Height="640" Width="940"
        MinHeight="560" MinWidth="820"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Bg}"
        FontFamily="Segoe UI" Foreground="{StaticResource Text}">

    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="370" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ============ LEFT: provider list ============ -->
        <Border Grid.Column="0" Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}"
                BorderThickness="0,0,1,0">
            <Grid Margin="18,20,18,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="DNS Servers" FontSize="18" FontWeight="SemiBold" />

                <!-- Search -->
                <Border Grid.Row="1" Margin="0,14,0,12" CornerRadius="10" Background="{StaticResource Bg}"
                        BorderBrush="{StaticResource Border}" BorderThickness="1" Height="40">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍" Margin="12,0,6,0" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextDim}" />
                        <TextBox x:Name="SearchBox" Grid.Column="1" Background="Transparent" BorderThickness="0"
                                 Foreground="{StaticResource Text}" CaretBrush="{StaticResource Accent}"
                                 VerticalContentAlignment="Center" TextChanged="SearchBox_TextChanged" />
                    </Grid>
                </Border>

                <!-- List -->
                <ListBox x:Name="ProviderList" Grid.Row="2" Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         SelectionChanged="ProviderList_SelectionChanged"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="0,0,0,8" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="card" CornerRadius="12" Background="{StaticResource Surface2}"
                                                BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="14,11">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="card" Property="Background" Value="#FF272C40" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="card" Property="Background" Value="{StaticResource AccentSoft}" />
                                                <Setter TargetName="card" Property="BorderBrush" Value="{StaticResource Accent}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" FontSize="14.5" FontWeight="SemiBold" />
                                        <Border Margin="8,1,0,0" CornerRadius="6" Background="#3359D499" Padding="6,1"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding IsCustom, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="custom" FontSize="10" Foreground="{StaticResource Success}" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding DisplayServers}" FontSize="12.5"
                                               Foreground="{StaticResource TextDim}" Margin="0,3,0,0" />
                                    <TextBlock Text="{Binding Note}" FontSize="11" Foreground="{StaticResource Accent}"
                                               Margin="0,2,0,0"
                                               Visibility="{Binding Note, Converter={StaticResource StrToVis}}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- List actions -->
                <Grid Grid.Row="3" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource GhostButton}" Content="＋ Add" Click="Add_Click" />
                    <Button Grid.Column="2" Style="{StaticResource GhostButton}" Content="✎ Edit"
                            Click="Edit_Click" x:Name="EditBtn" />
                    <Button Grid.Column="4" Style="{StaticResource DangerButton}" Content="🗑 Delete"
                            Click="Delete_Click" x:Name="DeleteBtn" />
                </Grid>
            </Grid>
        </Border>

        <!-- ============ RIGHT: details & actions ============ -->
        <Grid Grid.Column="1" Margin="28,24,28,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="DNS Changer" FontSize="26" FontWeight="Bold" />
                <TextBlock Text="Pick a DNS, choose your adapter, and apply with one click."
                           FontSize="13" Foreground="{StaticResource TextDim}" Margin="0,4,0,0" />
            </StackPanel>

            <!-- Adapter card -->
            <Border Grid.Row="1" Margin="0,22,0,0" CornerRadius="14" Background="{StaticResource Surface}"
                    BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="18,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="NETWORK ADAPTER" FontSize="11"
                               FontWeight="SemiBold" Foreground="{StaticResource TextDim}" />
                    <Button Grid.Row="0" Grid.Column="1" Content="⟳ Refresh" Style="{StaticResource GhostButton}"
                            Height="28" Padding="10,0" FontSize="12" Click="Refresh_Click" />

                    <ComboBox x:Name="AdapterBox" Grid.Row="1" Grid.ColumnSpan="2" Margin="0,10,0,0"
                              Style="{StaticResource Combo}" DisplayMemberPath="Display"
                              SelectionChanged="AdapterBox_SelectionChanged" />
                </Grid>
            </Border>

            <!-- Selected provider detail -->
            <Border Grid.Row="2" Margin="0,16,0,0" CornerRadius="14" Background="{StaticResource Surface}"
                    BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="22,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="SELECTED DNS" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextDim}" />
                        <TextBlock x:Name="SelName" Text="—" FontSize="22" FontWeight="Bold" Margin="0,6,0,0" />
                        <TextBlock x:Name="SelNote" Text="" FontSize="12" Foreground="{StaticResource Accent}"
                                   Margin="0,2,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,18">
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Primary" Foreground="{StaticResource TextDim}"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="SelPrimary" Grid.Column="1" Text="—" FontSize="17"
                                       FontFamily="Consolas" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Secondary" Foreground="{StaticResource TextDim}"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="SelSecondary" Grid.Column="1" Text="—" FontSize="17"
                                       FontFamily="Consolas" />
                        </Grid>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="220" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" x:Name="ApplyBtn" Style="{StaticResource PrimaryButton}"
                                Content="Apply DNS" Click="Apply_Click" />
                        <Button Grid.Column="2" Style="{StaticResource GhostButton}" Height="46"
                                Content="Reset to Automatic" Click="Clear_Click" />
                    </Grid>
                </Grid>
            </Border>

            <!-- Status bar -->
            <Border Grid.Row="3" Margin="0,16,0,0" CornerRadius="10" Background="{StaticResource Surface2}"
                    BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="14,10">
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="StatusDot" Width="9" Height="9" Fill="{StaticResource TextDim}"
                             VerticalAlignment="Center" Margin="0,0,10,0" />
                    <TextBlock x:Name="StatusText" Text="Ready." VerticalAlignment="Center"
                               Foreground="{StaticResource TextDim}" FontSize="12.5" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <TextBlock Grid.Row="4" Margin="0,10,0,0" FontSize="11" Foreground="{StaticResource TextDim}"
                       Text="Tip: run as administrator. Changes apply to the selected adapter only." />
        </Grid>
    </Grid>
</Window>
